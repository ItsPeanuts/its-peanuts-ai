# ── VorzaIQ Hetzner .env ────────────────────────────────────────────────────
# Kopieer dit bestand naar .env en vul alle waarden in
# NOOIT het echte .env bestand committen naar Git!

# ── Database (Render PostgreSQL) ────────────────────────────────────────────
DATABASE_URL=postgresql://its_peanuts_user:WACHTWOORD@dpg-XXXX.render.com/its_peanuts

# ── Auth ────────────────────────────────────────────────────────────────────
JWT_SECRET=genereer-een-lang-random-geheim-hier
BOOTSTRAP_TOKEN=Peanuts-Setup-2025!

# ── Admin account ───────────────────────────────────────────────────────────
ADMIN_EMAIL=admin@itspeanuts.ai
ADMIN_PASSWORD=verander-dit-naar-een-sterk-wachtwoord

# ── OpenAI ──────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...

# ── Email (Resend) ──────────────────────────────────────────────────────────
RESEND_API_KEY=re_...
FROM_EMAIL=VorzaIQ <noreply@JOUW_DOMEIN>

# ── URLs ────────────────────────────────────────────────────────────────────
FRONTEND_URL=https://JOUW_DOMEIN
NEXT_PUBLIC_API_BASE=https://api.JOUW_DOMEIN

# ── Stripe ──────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_...         # → sk_live_... na KvK
STRIPE_WEBHOOK_SECRET=whsec_...       # billing webhook signing secret
STRIPE_WEBHOOK_SECRET_PROMO=whsec_... # promoties webhook signing secret

STRIPE_PRICE_NORMAAL_MAAND=price_...
STRIPE_PRICE_NORMAAL_JAAR=price_...
STRIPE_PRICE_PREMIUM_MAAND=price_...
STRIPE_PRICE_PREMIUM_JAAR=price_...
STRIPE_PRICE_PER_VACATURE=price_...

STRIPE_PRICE_PROMO_7D=price_...
STRIPE_PRICE_PROMO_14D=price_...
STRIPE_PRICE_PROMO_30D=price_...

# ── D-ID Avatar (Lisa 1.0 — vervangen door Lisa 2.0) ────────────────────────
DID_API_KEY=
DID_PRESENTER_NAME=Amber
DID_PRESENTER_ID=IVHRp0a96W
DID_DRIVER_ID=rrGsQrSVpu
VIRTUAL_INTERVIEW_THRESHOLD=60

# ── Lisa 2.0 — OpenAI Realtime API (full-duplex voice) ──────────────────────
# Activeren: zet LISA_MAINTENANCE=false in frontend/app/candidate/interview/[id]/page.tsx
# OPENAI_API_KEY staat al boven — dit zijn aanvullende vars:

LISA_V2_VOICE=shimmer              # shimmer | alloy | nova | echo | fable | onyx

# ── Lisa 2.1 — Simli avatar (live lip-sync, TODO na eerste klanten) ─────────
# Aanmelden: https://simli.com → API key + face ID ophalen
# Installeer: npm install @simli/sdk  (in frontend/)
# Daarna: vervang de <video> tag in de interview page door Simli component
SIMLI_API_KEY=
SIMLI_FACE_ID=                     # Face ID uit Simli dashboard

# ── ElevenLabs TTS (optionele stem-upgrade, werkt ook zonder Realtime API) ──
# Aanmelden: https://elevenlabs.io → Creator plan $22/mo (100k tekens)
# Gebruik: backend/routers/virtual_interview.py → vervang OpenAI TTS calls
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=               # Voice ID uit ElevenLabs dashboard (bv. Rachel)

# ── Microsoft Teams (optioneel) ─────────────────────────────────────────────
MS_TENANT_ID=
MS_CLIENT_ID=
MS_CLIENT_SECRET=
MS_ORGANIZER_EMAIL=
